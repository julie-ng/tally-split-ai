{
  "name": "ai-receipts-poc",
  "version": "1.0.0",
  "description": "POC for analyzing receipt scans with handwritten expense splitting",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/**'",
    "test:integration": "vitest run tests/",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "lint": "eslint .",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "predev": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:init-user:local": "SUPABASE_ENV=local tsx server/db/seeds/seed-first-user.js",
    "db:init-user:dev": "SUPABASE_ENV=dev tsx server/db/seeds/seed-first-user.js",
    "db:init-user:prod": "SUPABASE_ENV=prod tsx server/db/seeds/seed-first-user.js",
    "supabase:migrate:dev": "SUPABASE_ENV=dev drizzle-kit migrate --config drizzle.supabase.ts",
    "supabase:migrate:prod": "SUPABASE_ENV=prod drizzle-kit migrate --config drizzle.supabase.ts",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "trigger:deploy:dev": "TRIGGER_PROJECT_ID=$TRIGGER_PROJECT_ID_DEV trigger deploy",
    "trigger:deploy:prod": "TRIGGER_PROJECT_ID=$TRIGGER_PROJECT_ID_PROD trigger deploy"
  },
  "imports": {
    "#shared/*": "./shared/*",
    "#server/*": "./server/*"
  },
  "keywords": [
    "azure",
    "document-intelligence",
    "receipts",
    "ocr"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure-rest/ai-document-intelligence": "^1.0.0",
    "@azure/storage-blob": "^12.25.0",
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/ui": "^4.3.0",
    "@nuxthub/core": "^0.10.4",
    "@pinia/nuxt": "^0.11.3",
    "@trigger.dev/sdk": "4.4.5",
    "@vercel/analytics": "^2.0.1",
    "@vueuse/core": "^14.1.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.2",
    "nanoid": "^5.1.11",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.29",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.82",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@trigger.dev/build": "^4.4.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.8",
    "sass-embedded": "^1.99.0",
    "trigger.dev": "^4.4.5",
    "vitest": "^4.0.15"
  }
}
