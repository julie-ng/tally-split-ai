{
  "name": "tally-split-ai",
  "private": true,
  "author": "Julie Ng",
  "description": "POC for analyzing receipt scans with handwritten expense splitting",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/**'",
    "test:integration": "vitest run tests/",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "lint": "eslint .",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "predev": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:init-user": "tsx server/db/seeds/seed-first-user.js",
    "trigger:dev": "trigger dev"
  },
  "imports": {
    "#shared/*": "./shared/*",
    "#server/*": "./server/*"
  },
  "keywords": [
    "azure",
    "document-intelligence",
    "receipts",
    "ocr"
  ],
  "dependencies": {
    "@azure-rest/ai-document-intelligence": "^1.0.0",
    "@azure/storage-blob": "^12.25.0",
    "@libsql/client": "^0.17.3",
    "@nuxt/content": "^3.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxthub/core": "^0.10.4",
    "@nuxtjs/mdc": "^0.21.1",
    "@pinia/nuxt": "^0.11.3",
    "@trigger.dev/sdk": "4.4.6",
    "@vercel/analytics": "^2.0.1",
    "@vueuse/core": "^14.1.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.1",
    "mermaid": "^11.15.0",
    "nanoid": "^5.1.11",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.107",
    "@iconify-json/material-icon-theme": "^1.2.64",
    "@iconify-json/simple-icons": "^1.2.81",
    "@nuxt/eslint": "^1.12.1",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@trigger.dev/build": "^4.4.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "sass-embedded": "^1.99.0",
    "trigger.dev": "^4.4.5",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "@depot/cli": "0.0.1-cli.2.101.60"
  }
